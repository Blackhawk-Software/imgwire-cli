{
  "name": "imgwire-cli",
  "description": "Upload, manage, transform, and inspect imgwire.dev images and resources from your terminal.",
  "version": "0.0.0",
  "author": "Blackhawk Software",
  "packageManager": "yarn@1.22.22",
  "bin": {
    "imgwire": "./bin/run.js"
  },
  "bugs": "https://github.com/Blackhawk-Software/imgwire-cli/issues",
  "dependencies": {
    "@imgwire/node": "^0.3.1",
    "@inquirer/prompts": "^8.4.2",
    "@napi-rs/keyring": "^1.3.0",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "@types/request": "^2.48.13",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "prettier": "^3.8.3",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/Blackhawk-Software/imgwire-cli",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "imgwire",
    "dirname": "imgwire",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "topics": {
      "cors-origin": {
        "description": "Manage CORS origins"
      },
      "custom-domain": {
        "description": "Manage the custom domain"
      },
      "images": {
        "description": "Manage images"
      },
      "metrics": {
        "description": "Inspect metrics"
      }
    }
  },
  "repository": "Blackhawk-Software/imgwire-cli",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "format": "prettier --write \"**/*.{js,mjs,ts,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,ts,json,md,yml,yaml}\"",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "yarn lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
